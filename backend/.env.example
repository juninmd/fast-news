# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://fastnews:fastnews_secret@localhost:5432/fastnews

# Redis
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# AI Provider — ollama | google | openai | anthropic
# ─────────────────────────────────────────────────────────────────────────────
AI_PROVIDER=ollama

# Ollama local (padrão — grátis, roda offline)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Google Gemini (alternativa cloud)
# AI_PROVIDER=google
# GEMINI_API_KEY=your_gemini_api_key_here
# ANALYSIS_MODEL=gemini-1.5-pro
# FAST_MODEL=gemini-1.5-flash

# OpenAI (alternativa cloud)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# ANALYSIS_MODEL=gpt-4o
# FAST_MODEL=gpt-4o-mini

# Anthropic (alternativa cloud)
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANALYSIS_MODEL=claude-3-5-sonnet-20241022
# FAST_MODEL=claude-3-5-haiku-20241022

# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Obtenha seu chat ID: abra @userinfobot no Telegram e envie qualquer mensagem
TELEGRAM_CHAT_IDS=123456789

# Categorias cujas notícias são postadas automaticamente no Telegram
TELEGRAM_NEWS_CATEGORIES=Mundo,Negócios,Brasil
# Máximo de notícias por ciclo de ingestion (a cada 30 min)
TELEGRAM_MAX_NEWS_PER_RUN=5

# ─────────────────────────────────────────────────────────────────────────────
# Cron Schedules
# ─────────────────────────────────────────────────────────────────────────────
CRON_INGESTION=*/30 * * * *
CRON_LEARNING=0 0 * * *
# 8h BRT (UTC-3) = 11h UTC
CRON_DIGEST=0 11 * * *

# ─────────────────────────────────────────────────────────────────────────────
# Ingestion / RAG Config
# ─────────────────────────────────────────────────────────────────────────────
INGESTION_BATCH_SIZE=10
MAX_ARTICLES_PER_FEED=20
RAG_TOP_K=10

# true = pula ingestion inicial ao subir o servidor (útil em dev)
SKIP_INITIAL_INGESTION=false
