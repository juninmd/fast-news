# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# AI Provider Configuration for Agent
AI_PROVIDER=ollama # 'ollama' or 'ai-sdk'
AI_SDK_PROVIDER=openai # 'openai', 'anthropic', 'google', 'mistral', or 'deepseek'
AI_SDK_API_KEY=your_api_key_here
AI_SDK_MODEL= # Optional: Provide a specific model string (e.g. gpt-4o-mini, claude-3-haiku-20240307, mistral-large-latest, deepseek-chat)
