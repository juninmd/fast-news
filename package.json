{
	"name": "fast-news",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"news-agent": "node scripts/news-agent.js",
		"start-agent": "node scripts/news-agent.js --loop",
		"lint": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"dev:api": "pnpm --filter @fast-news/api dev",
		"dev:mcp": "pnpm --filter @fast-news/mcp dev"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"@vitejs/plugin-react": "^6.0.3",
		"autoprefixer": "^10.5.0",
		"dotenv": "^17.4.2",
		"lucide-react": "^1.21.0",
		"postcss": "^8.5.15",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-markdown": "^10.1.0",
		"rss-parser": "^3.13.0",
		"tailwindcss": "^4.3.1",
		"vite": "^8.0.16"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@tailwindcss/postcss": "^4.3.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.1.9",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"msw": "^2.14.6",
		"vitest": "^4.0.17"
	}
}
